# Server
PORT=3001
NODE_ENV=development

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=

# HuggingFace — get from huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Qdrant Cloud — get from cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=textbook_chunks

# Neon (PostgreSQL) — get from neon.tech
DATABASE_URL=

# Better-Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# CORS — frontend origin
FRONTEND_URL=http://localhost:3000
